{
  "name": "bitcoin-serverless-donations",
  "version": "1.0.22",
  "author": "https://github.com/bennet-org/bitcoin-serverless-donations",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bennet-org/bitcoin-serverless-donations.git"
  },
  "type": "module",
  "keywords": [
    "bitcoin",
    "donations",
    "payments",
    "xpub",
    "netlify"
  ],
  "scripts": {
    "dev": "npx netlify-cli dev",
    "build": "node build.js",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@netlify/blobs": "10.7.9",
    "@netlify/functions": "5.3.0",
    "@noble/curves": "^2.2.0",
    "@noble/hashes": "^2.2.0",
    "@scure/base": "^2.2.0",
    "@scure/bip32": "^2.2.0",
    "cssnano": "8.0.2",
    "postcss": "8.5.15",
    "terser": "5.48.0",
    "typescript": "^6.0.3",
    "vitest": "4.1.9"
  },
  "main": "dist/bitcoin-pay.min.js",
  "module": "dist/bitcoin-pay.esm.js",
  "types": "dist/bitcoin-pay.d.ts",
  "exports": {
    ".": {
      "types": "./dist/bitcoin-pay.d.ts",
      "import": "./dist/bitcoin-pay.esm.js",
      "require": "./dist/bitcoin-pay.min.js",
      "default": "./dist/bitcoin-pay.min.js"
    },
    "./esm": "./dist/bitcoin-pay.esm.js",
    "./cdn": "./dist/bitcoin-pay.min.js",
    "./css": "./dist/bitcoin-pay.min.css"
  },
  "files": [
    "dist/",
    "bitcoin-pay.d.ts",
    "README.md"
  ]
}
